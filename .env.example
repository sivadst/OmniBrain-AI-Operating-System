# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO

# Authentication
API_KEY=your_secure_api_key_here

# Database Settings
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/omnibrain
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# LLM Providers (Sandbox Default to Ollama)
OLLAMA_BASE_URL=http://localhost:11434
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Model Routing Configuration
REASONING_MODEL=ollama/llama3
CODING_MODEL=ollama/llama3
FAST_MODEL=ollama/llama3
